+    fn detect_total_cpu_cores(sys: &System) -> usize {
+        let sysinfo_count = sys.cpus().len();
+        if sysinfo_count > 0 {
+            return sysinfo_count;
+        }
+
+        if let Ok(parallelism) = std::thread::available_parallelism() {
+            let count = parallelism.get();
+            if count > 0 {
+                return count;
+            }
+        }
+
+        if let Some(cpu_count) = Self::read_cpu_count_from_sysfs() {
+            return cpu_count;
+        }
+
+        if let Some(cpu_count) = Self::read_cpu_count_from_proc_cpuinfo() {
+            return cpu_count;
+        }
+
+        0
     }
 
+    fn read_cpu_count_from_sysfs() -> Option<usize> {
+        #[cfg(any(target_os = "linux", target_os = "android"))]
+        {
+            if let Ok(text) = std::fs::read_to_string("/sys/devices/system/cpu/present") {
+                if let Some(count) = Self::parse_cpu_range_count(&text) {
+                    return Some(count);
+                }
+            }
+
+            let entries = std::fs::read_dir("/sys/devices/system/cpu").ok()?;
+            let mut count = 0usize;
+            for entry in entries.flatten() {
+                let file_name = entry.file_name();
+                let name = file_name.to_string_lossy();
+                let Some(suffix) = name.strip_prefix("cpu") else {
+                    continue;
+                };
+                if !suffix.is_empty() && suffix.chars().all(|ch| ch.is_ascii_digit()) {
+                    count += 1;
+                }
+            }
+
+            return (count > 0).then_some(count);
+        }
+
+        #[cfg(not(any(target_os = "linux", target_os = "android")))]
+        {
+            None
+        }
+    }
+
+    fn parse_cpu_range_count(text: &str) -> Option<usize> {
+        let mut count = 0usize;
+
+        for part in text.trim().split(',').map(str::trim).filter(|part| !part.is_empty()) {
+            if let Some((start, end)) = part.split_once('-') {
+                let start = start.trim().parse::<usize>().ok()?;
+                let end = end.trim().parse::<usize>().ok()?;
+                if end < start {
+                    return None;
+                }
+                count += end - start + 1;
+            } else {
+                part.parse::<usize>().ok()?;
+                count += 1;
+            }
+        }
+
+        (count > 0).then_some(count)
+    }
